    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "framer-motion": "^12.40.0",
    "groq-sdk": "^0.9.0",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
